{
	"name": "medusa-plugin-mildred",
	"version": "0.1.0",
	"description": "Privacy-first analytics plugin for Medusa v2",
	"author": "Lacey Pevey",
	"files": [
		".medusa/server"
	],
	"exports": {
		"./package.json": "./package.json",
		"./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
		"./modules/*": "./.medusa/server/src/modules/*/index.js",
		"./providers/*": "./.medusa/server/src/providers/*/index.js",
		"./*": "./.medusa/server/src/*.js",
		"./admin": {
			"import": "./.medusa/server/src/admin/index.mjs",
			"require": "./.medusa/server/src/admin/index.js",
			"default": "./.medusa/server/src/admin/index.js"
		},
		".": "./.medusa/server/src/modules/analytics/index.js"
	},
	"keywords": [
		"medusa-plugin-integration",
		"medusa-v2",
		"medusa",
		"medusa-plugin-mildred",
		"mildred",
		"analytics",
		"privacy"
	],
	"scripts": {
		"build": "medusa plugin:build",
		"dev": "medusa plugin:develop",
		"prepublishOnly": "medusa plugin:build",
		"test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --detectOpenHandles --forceExit --passWithNoTests"
	},
	"dependencies": {
		"recharts": "^2.15.0"
	},
	"devDependencies": {
		"@medusajs/admin-sdk": "2.13.6",
		"@medusajs/cli": "2.13.6",
		"@medusajs/framework": "2.13.6",
		"@medusajs/icons": "2.13.6",
		"@medusajs/medusa": "2.13.6",
		"@medusajs/test-utils": "2.13.6",
		"@medusajs/ui": "4.0.25",
		"@swc/core": "^1.7.28",
		"@swc/jest": "^0.2.39",
		"@types/jest": "^30.0.0",
		"@types/node": "^20.0.0",
		"@types/react": "^18.3.2",
		"@types/react-dom": "^18.2.25",
		"jest": "^29.7.0",
		"prop-types": "^15.8.1",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"ts-node": "^10.9.2",
		"typescript": "^5.6.2",
		"vite": "^5.2.11",
		"yalc": "^1.0.0-pre.53"
	},
	"peerDependencies": {
		"@medusajs/admin-sdk": "2.13.6",
		"@medusajs/cli": "2.13.6",
		"@medusajs/framework": "2.13.6",
		"@medusajs/icons": "2.13.6",
		"@medusajs/medusa": "2.13.6",
		"@medusajs/test-utils": "2.13.6",
		"@medusajs/ui": "4.0.25"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
