{
	"name": "medusa-plugin-analytics",
	"version": "0.2.0",
	"description": "Privacy-first analytics plugin for Medusa v2",
	"author": "Lacey Pevey",
	"repository": {
		"type": "git",
		"url": "https://github.com/pevey/medusa-plugins"
	},
	"homepage": "https://pevey.com/medusa-plugin-analytics",
	"files": [
		".medusa/server"
	],
	"exports": {
		"./package.json": "./package.json",
		"./admin": {
			"import": "./.medusa/server/src/admin/index.mjs",
			"require": "./.medusa/server/src/admin/index.js",
			"default": "./.medusa/server/src/admin/index.js"
		},
		"./.medusa/server/src/modules/*": {
			"types": "./.medusa/server/src/modules/*/index.d.ts",
			"default": "./.medusa/server/src/modules/*/index.js"
		},
		"./modules/*": {
			"types": "./.medusa/server/src/modules/*/index.d.ts",
			"default": "./.medusa/server/src/modules/*/index.js"
		},
		"./providers/*": {
			"types": "./.medusa/server/src/providers/*/index.d.ts",
			"default": "./.medusa/server/src/providers/*/index.js"
		},
		"./*": {
			"types": "./.medusa/server/src/*.d.ts",
			"default": "./.medusa/server/src/*.js"
		},
		".": {
			"types": "./.medusa/server/src/providers/analytics-private/index.d.ts",
			"default": "./.medusa/server/src/providers/analytics-private/index.js"
		}
	},
	"keywords": [
		"medusa-v2",
		"medusa",
		"private analytics",
		"analytics",
		"privacy",
		"customer analytics"
	],
	"scripts": {
		"build": "medusa plugin:build",
		"dev": "medusa plugin:develop",
		"prepublishOnly": "medusa plugin:build",
		"test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --detectOpenHandles --forceExit --passWithNoTests",
		"test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --detectOpenHandles --forceExit"
	},
	"dependencies": {
		"recharts": "2.15.0"
	},
	"devDependencies": {
		"@medusajs/admin-sdk": "2.14.2",
		"@medusajs/cli": "2.14.2",
		"@medusajs/framework": "2.14.2",
		"@medusajs/icons": "2.14.2",
		"@medusajs/ui": "4.1.9",
		"@swc/core": "1.15.33",
		"@swc/jest": "0.2.39",
		"@types/jest": "30.0.0",
		"@types/node": "20.0.0",
		"@types/react": "18.3.2",
		"@types/react-dom": "18.2.25",
		"jest": "29.7.0",
		"prop-types": "15.8.1",
		"react": "18.3.1",
		"react-dom": "18.3.1",
		"ts-node": "10.9.2",
		"typescript": "6.0.3",
		"vite": "8.0.8",
		"yalc": "1.0.0-pre.53"
	},
	"peerDependencies": {
		"@medusajs/framework": "2.14.2",
		"@medusajs/js-sdk": "2.14.2",
		"@medusajs/medusa": "2.14.2"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
