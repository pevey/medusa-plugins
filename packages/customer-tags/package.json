{
	"name": "medusa-plugin-customer-tags",
	"version": "0.1.3",
	"description": "Customer tagging plugin for Medusa v2",
	"author": "Lacey Pevey",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/pevey/medusa-plugins"
	},
	"homepage": "https://pevey.com/medusa-plugin-customer-tags",
	"files": [
		".medusa/server"
	],
	"exports": {
		"./package.json": "./package.json",
		"./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
		"./modules/*": "./.medusa/server/src/modules/*/index.js",
		"./providers/*": "./.medusa/server/src/providers/*/index.js",
		"./*": "./.medusa/server/src/*.js",
		".": "./.medusa/server/src/modules/customer-tag/index.js"
	},
	"keywords": [
		"medusa-plugin",
		"medusa-v2",
		"medusa",
		"customer tags",
		"tagging"
	],
	"scripts": {
		"build": "medusa plugin:build",
		"clean:snapshots": "find . -name '.snapshot-*.json' -path '*/migrations/*' -delete",
		"dev": "medusa plugin:develop",
		"prepublishOnly": "medusa plugin:build",
		"test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --detectOpenHandles --forceExit --passWithNoTests",
		"test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --detectOpenHandles --forceExit"
	},
	"devDependencies": {
		"@medusajs/admin-sdk": "2.13.6",
		"@medusajs/cli": "2.13.6",
		"@medusajs/framework": "2.13.6",
		"@medusajs/icons": "2.13.6",
		"@medusajs/js-sdk": "2.13.6",
		"@medusajs/medusa": "2.13.6",
		"@medusajs/test-utils": "2.13.6",
		"@medusajs/ui": "4.0.25",
		"@swc/core": "^1.7.28",
		"@swc/jest": "^0.2.39",
		"@types/jest": "^30.0.0",
		"@types/node": "^20.0.0",
		"@types/react": "^18.3.2",
		"@types/react-dom": "^18.2.25",
		"jest": "^29.7.0",
		"prop-types": "^15.8.1",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"ts-node": "^10.9.2",
		"typescript": "^5.6.2",
		"vite": "^5.2.11",
		"yalc": "^1.0.0-pre.53"
	},
	"peerDependencies": {
		"@medusajs/admin-sdk": "2.13.6",
		"@medusajs/cli": "2.13.6",
		"@medusajs/framework": "2.13.6",
		"@medusajs/icons": "2.13.6",
		"@medusajs/medusa": "2.13.6",
		"@medusajs/test-utils": "2.13.6",
		"@medusajs/ui": "4.0.25"
	},
	"engines": {
		"node": ">=20"
	}
}