{
	"name": "backend",
	"private": true,
	"description": "A test server for developing and testing Medusa plugins.",
	"scripts": {
		"build": "medusa build && cp -R tax-data .medusa/server && cp -R static .medusa/server && cp .env .medusa/server",
		"db:migrate": "medusa db:migrate",
		"db:generate": "medusa db:generate",
		"preview:emails": "email dev --dir ./src/templates",
		"predev": "node ../../scripts/dedupe-medusa.cjs",
		"dev": "medusa develop",
		"start": "medusa start"
	},
	"dependencies": {
		"@medusajs/admin-sdk": "2.13.6",
		"@medusajs/cli": "2.13.6",
		"@medusajs/framework": "2.13.6",
		"@medusajs/index": "2.13.6",
		"@medusajs/medusa": "2.13.6",
		"@react-email/components": "1.0.12",
		"@react-email/render": "2.0.6",
		"medusa-plugin-analytics": "workspace:*",
		"medusa-plugin-automation": "workspace:*",
		"medusa-plugin-braintree": "workspace:*",
		"medusa-plugin-content": "workspace:*",
		"medusa-plugin-customer-tags": "workspace:*",
		"medusa-plugin-order-notes": "workspace:*",
		"medusa-plugin-r2": "workspace:*",
		"medusa-plugin-ratings": "workspace:*",
		"medusa-plugin-ses": "workspace:*",
		"medusa-plugin-statistics": "workspace:*",
		"medusa-plugin-tax-lookup": "workspace:*",
		"medusa-plugin-tracing": "workspace:*",
		"medusa-plugin-veeqo": "workspace:*"
	},
	"devDependencies": {
		"@react-email/preview-server": "5.2.10",
		"@swc/core": "1.15.24",
		"@swc/jest": "0.2.39",
		"@testing-library/dom": "10.4.1",
		"@testing-library/react": "16.3.2",
		"@types/jest": "30.0.0",
		"@types/node": "20.19.39",
		"@types/react": "18.3.28",
		"@types/react-dom": "18.3.7",
		"@vitejs/plugin-react": "6.0.1",
		"happy-dom": "20.8.9",
		"jest": "29.7.0",
		"msw": "2.13.2",
		"prop-types": "15.8.1",
		"react": "18.3.1",
		"react-dom": "18.3.1",
		"react-email": "5.2.10",
		"ts-node": "10.9.2",
		"tsx": "4.21.0",
		"typescript": "^5.6.2",
		"vite": "8.0.8",
		"vitest": "4.1.4",
		"yalc": "1.0.0-pre.53"
	},
	"engines": {
		"node": ">=20"
	}
}
